      <div class="stage" style="opacity:0.45">
        <span class="num">[${String(i+1).padStart(2,'0')}]</span>
        <span class="body">${row[0]} <small>pending</small></span>
        <span class="ms">—</span>
      </div>`).join('');
  }

  async function runScenario() {
    const s = scenarioData[activeId];
    runBtn.disabled = true; runBtn.style.opacity = 0.6;
    verdictWrap.innerHTML = ''; receiptWrap.innerHTML = '';
    // Reveal stages one at a time
    const total = s.stages.length;
    for (let i = 0; i < total; i++) {
      const row = s.stages[i];
      const stageEl = stagesEl.children[i];
      stageEl.classList.add(row[3]);
      stageEl.style.opacity = 1;
      stageEl.querySelector('.body').innerHTML = `${row[0]} <small>${row[1]}</small>`;
      stageEl.querySelector('.ms').textContent = row[2] + 'ms';
      await new Promise(r => setTimeout(r, 220 + Math.random()*80));
    }
    renderVerdict(s);
    prependChain(s, nowStr());
    blockNum += 1;
    blockEl.textContent = blockNum.toLocaleString();
    runBtn.disabled = false; runBtn.style.opacity = 1;
  }

  /* Wire events */
  document.querySelectorAll('.scen').forEach(b => {
    b.addEventListener('click', () => {
      loadScenario(b.dataset.id);
      runScenario();
    });
  });
  document.querySelectorAll('.editor-tabs .tab').forEach(t => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.editor-tabs .tab').forEach(x => x.classList.remove('active'));
      t.classList.add('active');
      activeTab = t.dataset.t;
      setEditorTab(activeId, activeTab);
    });
  });
  runBtn.addEventListener('click', runScenario);

  /* Init */
  seedChain();
  loadScenario('allow-1');
  setTimeout(runScenario, 320);
})();
</script>
