  /* Helpers */
  function setEditorTab(scenId, tab) {
    const lines = tabContent[scenId][tab];
    editor.innerHTML = lines.map(l => `<span class="line">${l[0]}</span>`).join('');
  }
  function renderStages(s) {
    stagesEl.innerHTML = s.stages.map((row, i) => `
      <div class="stage ${row[3]}">
        <span class="num">[${String(i+1).padStart(2,'0')}]</span>
        <span class="body">${row[0]} <small>${row[1]}</small></span>
        <span class="ms">${row[2]}ms</span>
      </div>`).join('');
  }
  function renderVerdict(s) {
    verdictWrap.innerHTML = `
      <div class="verdict" data-v="${s.verdict}">
        <div class="v-tag">${s.verdictTag}</div>
        <div class="v-name">${s.verdictName}</div>
        <div class="v-why">${s.why}</div>
        <div class="v-ms">total: ${s.ms}ms · receipt sealed</div>
      </div>`;
    receiptWrap.innerHTML = `
      <div class="receipt">
        <h5>// signed receipt</h5>
        <div class="row"><span class="k">id</span><span class="v hash">${s.receipt.id}</span></div>
        <div class="row"><span class="k">agent</span><span class="v">${s.receipt.agent}</span></div>
        <div class="row"><span class="k">action</span><span class="v">${s.receipt.action}</span></div>
        <div class="row"><span class="k">tier</span><span class="v">${s.receipt.tier}</span></div>
        <div class="row"><span class="k">cap</span><span class="v">${s.receipt.cap}</span></div>
        <div class="row"><span class="k">sig</span><span class="v sig">${s.receipt.sig}</span></div>
      </div>`;
  }
  function prependChain(s, time) {
    const rowHtml = `
      <div class="chain-row new ${s.chainKind}" data-v="${s.verdict}">
        <div class="glyph">${s.verdict === 'allow' ? '✓' : s.verdict === 'deny' ? '✗' : '⚠'}</div>
        <div class="body">
          <div class="meta">
            <span>${time}</span>
            <span>${s.verdictName}</span>
            <span>${s.ms}ms</span>
          </div>
          <div class="what">${s.chainWhat}</div>
          <div class="hash">${s.receipt.id}</div>
        </div>
      </div>`;
    chainEl.insertAdjacentHTML('afterbegin', rowHtml);
    while (chainEl.children.length > 5) chainEl.removeChild(chainEl.lastChild);
    const first = chainEl.firstElementChild;
    setTimeout(() => first.classList.remove('new'), 700);
  }

  /* Time helper */
  function nowStr() {
    const d = new Date();
    return d.toLocaleTimeString('en-US', { hour12: false });
  }

  /* Seed chain with a few prior receipts (allow-heavy) */
  function seedChain() {
    const seed = [
      { verdict:'allow', verdictName:'ALLOW', ms:34, receipt:{ id:'0x9bb1c241aa9d…' }, chainKind:'allow', chainWhat:'<span class="agent">claude-procurement</span> · contract.review' },
      { verdict:'allow', verdictName:'ALLOW', ms:29, receipt:{ id:'0xc4421ee03a01…' }, chainKind:'allow', chainWhat:'<span class="agent">market-scout-prod</span> · db.read(trades)' },
      { verdict:'allow', verdictName:'ALLOW', ms:31, receipt:{ id:'0x6b104caa28c3…' }, chainKind:'allow', chainWhat:'<span class="agent">on-call-bot</span> · pagerduty.notify' },
      { verdict:'esc',   verdictName:'ESCALATE', ms:18, receipt:{ id:'0x77a8c0bb1322…' }, chainKind:'esc',   chainWhat:'<span class="agent">qa-runner</span> · shell.exec ⚠' },
      { verdict:'deny',  verdictName:'DENY',  ms:8,  receipt:{ id:'0xeaa01298d12c…' }, chainKind:'deny',  chainWhat:'<span class="agent">research-pal</span> · net.out(blocked)' },
    ];
    seed.reverse().forEach(s => prependChain(s, nowStr()));
    chainEl.querySelectorAll('.chain-row.new').forEach(r => r.classList.remove('new'));
  }

