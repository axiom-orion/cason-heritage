        <li><a href="#">License</a></li>
      </ul></div>
      <div><h4>Family</h4><ul>
        <li><a href="vorion-www.html">Vorion.org</a></li>
        <li><a href="agentanchor-www.html">AgentAnchor</a></li>
        <li><a href="aurais-www.html">Aurais</a></li>
      </ul></div>
    </div>
    <div class="legal">
      <span>© 2026 Vorion LLC · Apache-2.0</span>
      <span>v 0.9.4 · build 8842 · status: ●all systems normal</span>
