</footer>

</div>
</BaseLayout>

<style is:global>
/* ── Cognigate is the dev-first property: terminals, code, latency lines ── */
  .hero-cog { padding: 88px 0 64px; }
  .hero-cog .grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: 56px; align-items: center; }
  .hero-cog .actions { display: flex; gap: 12px; margin-bottom: 28px; }

  .install-line {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 10px 16px; background: #0F172A; color: #E2E8F0;
    border-radius: 8px;
    font-family: var(--font-mono); font-size: 13px;
    border: 1px solid #1E293B;
  }
  .install-line .prompt { color: #10B981; }
  .install-line .copy { margin-left: 12px; color: #64748B; cursor: pointer; font-size: 11px; letter-spacing: 0.1em; }
  .install-line .copy:hover { color: #E2E8F0; }

  /* Code preview */
  .code-frame {
    background: #0B1120; border-radius: 12px; overflow: hidden;
    border: 1px solid #1E293B;
    box-shadow: 0 24px 60px -28px rgba(15,23,42,0.4);
  }
  .code-frame .tabs {
    display: flex; align-items: center; gap: 0;
    background: #050912; border-bottom: 1px solid #1E293B;
    padding: 0 8px; height: 38px;
  }
  .code-frame .tab {
    padding: 0 14px; height: 100%; display: flex; align-items: center;
    font-family: var(--font-mono); font-size: 11px; color: #64748B;
    border-right: 1px solid #1E293B;
  }
  .code-frame .tab.active { background: #0B1120; color: #E2E8F0; }
  .code-frame .tab .dot { width: 6px; height: 6px; border-radius: 50%; background: #10B981; margin-right: 8px; }
  .code-frame .lights { display: flex; gap: 6px; padding: 0 12px 0 4px; }
  .code-frame .lights span { width: 11px; height: 11px; border-radius: 50%; background: #1E293B; }
  .code-frame pre {
    margin: 0; padding: 24px 28px;
    font-family: var(--font-mono); font-size: 13.5px; line-height: 1.7;
    color: #E2E8F0;
    overflow: auto;
  }
  .code-frame .ln { color: #334155; user-select: none; padding-right: 14px; display: inline-block; width: 24px; text-align: right; }
  .code-frame .kw { color: #C084FC; }
  .code-frame .fn { color: #60A5FA; }
  .code-frame .str { color: #34D399; }
  .code-frame .num { color: #FBBF24; }
  .code-frame .com { color: #475569; font-style: italic; }
  .code-frame .var { color: #F1F5F9; }
  .code-frame .pkg { color: #FB7185; }
  .code-frame .hi { background: rgba(16,185,129,0.10); display: block; margin: 0 -28px; padding: 0 28px; border-left: 2px solid #10B981; }

  /* Latency band */
  .latency-band {
    background: #050912; color: #E2E8F0;
    padding: 12px 16px; border-top: 1px solid #1E293B;
    display: grid; grid-template-columns: auto 1fr auto auto auto;
    gap: 14px; align-items: center;
    font-family: var(--font-mono); font-size: 11px;
  }
  .latency-band .lbl { color: #64748B; letter-spacing: 0.1em; }
  .latency-band .val { color: #10B981; font-weight: 600; }
  .latency-band .bar { height: 4px; background: #1E293B; border-radius: 2px; overflow: hidden; }
  .latency-band .bar > span { display: block; height: 100%; background: linear-gradient(90deg, #10B981, #34D399); width: 28%; }

  /* Decision panel */
  .decision-card {
    background: #0B1120; border: 1px solid #1E293B; border-radius: 12px;
    overflow: hidden; color: #E2E8F0;
  }
  .decision-card .head {
    background: #050912; padding: 14px 18px; border-bottom: 1px solid #1E293B;
    display: flex; align-items: center; gap: 12px;
    font-family: var(--font-mono); font-size: 11px; color: #64748B; letter-spacing: 0.1em;
  }
  .decision-card .head .ok { color: #10B981; }
  .decision-card .body { padding: 18px; }

  /* Steps timeline */
  .timeline { display: grid; gap: 0; }
  .step {
    display: grid; grid-template-columns: 56px 1fr;
    gap: 24px; padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .step:first-child { border-top: none; }
  .step .num {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em;
    color: var(--site-accent); padding-top: 4px;
  }
  .step h3 { font-size: 22px; margin: 0 0 10px; letter-spacing: -0.015em; }
  .step p { color: var(--fg-muted); margin: 0 0 16px; max-width: 60ch; }

  /* Stats / SDKs */
  .sdk-grid { display: grid; grid-template-columns: repeat(6,1fr); gap: 12px; }
  .sdk-pill {
    padding: 18px 14px; border: 1px solid var(--border); border-radius: 10px;
    background: var(--bg); text-align: center;
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em;
    display: flex; flex-direction: column; gap: 4px;
  }
  .sdk-pill .v { color: var(--fg-muted); font-size: 10px; }
  .sdk-pill.shipping { border-color: var(--site-accent); color: var(--site-accent); }
  .sdk-pill.soon { color: var(--fg-muted); border-style: dashed; }

  .perf-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
  .perf {
    padding: 28px; border: 1px solid var(--border); border-radius: 12px; background: var(--bg);
